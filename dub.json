{
    "name": "d-nanoflann",
    "description": "D bindings for a thin C shim around jlblancoc/nanoflann — header-only C++ KD-tree for nearest-point queries on 3-D float clouds.",
    "license": "BSD-2-Clause",
    "authors": ["Alexander Shagarov"],

    "sourcePaths": ["source"],
    "importPaths": ["source"],

    "preBuildCommands-posix": [
        "cd \"$PACKAGE_DIR\" && git submodule update --init --recursive --quiet",
        "cmake -S \"$PACKAGE_DIR\" -B \"$PACKAGE_DIR/build\" -DCMAKE_BUILD_TYPE=Release -DBUILD_SHARED_LIBS=OFF",
        "cmake --build \"$PACKAGE_DIR/build\" -j --target nanoflann_c"
    ],
    "lflags-posix": ["-L$PACKAGE_DIR/build"],
    "libs-linux": ["nanoflann_c", "stdc++", "m"],
    "libs-osx": ["nanoflann_c", "c++", "m"],

    "preBuildCommands-windows": [
        "git -C \"$PACKAGE_DIR\" submodule update --init --recursive",
        "cmake -S \"$PACKAGE_DIR\" -B \"$PACKAGE_DIR/build\"",
        "cmake --build \"$PACKAGE_DIR/build\" --config Release --target nanoflann_c"
    ],
    "lflags-windows": ["$PACKAGE_DIR/build/Release/nanoflann_c.lib"],
    "dflags-windows": ["-mscrtlib=msvcrt"],

    "configurations": [
        {
            "name": "library",
            "targetType": "staticLibrary"
        },
        {
            "name": "nearest",
            "targetType": "executable",
            "targetName": "nearest",
            "mainSourceFile": "examples/nearest.d"
        }
    ]
}
